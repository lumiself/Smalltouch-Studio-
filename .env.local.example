# Supabase — get these from your Supabase project settings
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Supabase service role (server-side only, never expose to frontend)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Retouch4me (server-side only — never expose to frontend)
# Get token at: https://retouch4.me/token_page
RETOUCH4ME_TOKEN=your-retouch4me-token

# Replicate (server-side only)
REPLICATE_API_KEY=your-replicate-key

# Admin — protects /admin routes and token code generation
ADMIN_SECRET_KEY=choose-a-strong-random-secret

# Admin email — the Supabase user with this email can access /admin and generate codes
# Both server-side (ADMIN_EMAIL) and client-side (VITE_ADMIN_EMAIL) must be set and match
ADMIN_EMAIL=admin@example.com
VITE_ADMIN_EMAIL=admin@example.com
